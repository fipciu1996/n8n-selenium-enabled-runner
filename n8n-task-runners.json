{
  "task-runners": [
    {
      "runner-type": "javascript",
      "workdir": "/home/runner",
      "command": "/usr/local/bin/node",
      "args": ["/opt/runners/task-runner-javascript/dist/start.js"],
      "health-check-server-port": "5681",
      "allowed-env": [
        "N8N_RUNNERS_MAX_CONCURRENCY",
        "N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT",
        "N8N_RUNNERS_TASK_TIMEOUT",
        "N8N_RUNNERS_TASK_BROKER_URI",
        "N8N_RUNNERS_BROKER_LISTEN_ADDRESS",
        "N8N_RUNNERS_BROKER_PORT",
        "N8N_RUNNERS_HEALTH_CHECK_SERVER_ENABLED",
        "N8N_RUNNERS_HEALTH_CHECK_SERVER_HOST",
        "N8N_RUNNERS_HEALTH_CHECK_SERVER_PORT",
        "N8N_RUNNERS_AUTH_TOKEN",
        "N8N_RUNNERS_LAUNCHER_LOG_LEVEL",
        "GENERIC_TIMEZONE",
        "NODE_FUNCTION_ALLOW_BUILTIN",
        "NODE_FUNCTION_ALLOW_EXTERNAL",
        "N8N_RUNNERS_ALLOW_PROTOTYPE_MUTATION",
        "N8N_RUNNERS_ALLOW_BLOB_ACCESS",
        "N8N_RUNNERS_ALLOW_BUILTIN_MODULES"
      ],
      "env-overrides": {
        "N8N_RUNNERS_HEALTH_CHECK_SERVER_HOST": "0.0.0.0",
        "NODE_FUNCTION_ALLOW_BUILTIN": "crypto",
        "NODE_FUNCTION_ALLOW_EXTERNAL": "moment"
      }
    },
    {
      "runner-type": "python",
      "workdir": "/home/runner",
      "command": "/opt/runners/task-runner-python/.venv/bin/python",
      "args": ["-I", "-B", "-X", "disable_remote_debug", "-m", "src.main"],
      "health-check-server-port": "5682",
      "allowed-env": [
        "PATH",
        "N8N_RUNNERS_LAUNCHER_LOG_LEVEL",
        "N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT",
        "N8N_RUNNERS_TASK_TIMEOUT",
        "N8N_RUNNERS_MAX_CONCURRENCY",
        "N8N_SENTRY_DSN",
        "N8N_VERSION",
        "ENVIRONMENT",
        "DEPLOYMENT_NAME"
      ],
      "env-overrides": {
        "N8N_RUNNERS_STDLIB_ALLOW": "io,zoneinfo,re,unicodedata,urllib,pathlib,time,json,csv,loguru,python-gitlab,requests,selenium,webdriver-manager,pandas,numpy,os,webdriver_manager.core.os_manager,webdriver_manager.chrome,datetime",
        "N8N_RUNNERS_EXTERNAL_ALLOW": "io,zoneinfo,re,unicodedata,urllib,pathlib,time,loguru,python-gitlab,requests,selenium,webdriver-manager,pandas,numpy,webdriver_manager.chrome,webdriver_manager.core.os_manager,datetime"
      }
    }
  ]
}
